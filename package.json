{
  "name": "@cloro-dev/openclaw-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin exposing cloro's AI-visibility monitoring tools: ChatGPT, Perplexity, Gemini, Copilot, Google AI Mode, Google Search, and Google News.",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "cloro",
    "ai-visibility",
    "brand-monitoring",
    "serp"
  ],
  "homepage": "https://cloro.dev",
  "scripts": {
    "build": "esbuild index.ts --format=esm --target=node20 --outfile=dist/index.js"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11"
    }
  }
}
